import objetos.*
import wollok.game.*

describe "Saque lateral" {
   method initialize() {
        lionel.position(game.at(3, 5))
        pelota.position(game.at(5, 5))
    }

    test "Pelota y Lionel van a y=0, Lionel a la izquierda de la pelota" {
        lionel.realizarSaqueLateral()
        assert.equals(pelota.position(), game.at(5, 0))
        assert.equals(lionel.position(), game.at(4, 0)) 
    }
}